# Zendesk domain (e.g. dnsfilter.zendesk.com)
ZENDESK_DOMAIN=dnsfilter.zendesk.com

# Service account email for API token auth
ZENDESK_EMAIL=service-account@dnsfilter.com

# API token (from Zendesk Admin > Apps and integrations > Zendesk API > API token)
ZENDESK_API_TOKEN=your_api_token_here

# HTTP server port
PORT=8000
