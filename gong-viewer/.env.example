# Gong service-account API credentials (Tech Admin generated, company-scoped).
# Auth is HTTP Basic: GONG_ACCESS_KEY as username, GONG_SECRET_KEY as password.
GONG_ACCESS_KEY=your_access_key_here
GONG_SECRET_KEY=your_secret_key_here

# Gong REST API base URL. Default works for most tenants.
# Override only if your tenant requires a region-specific endpoint
# (e.g. https://us-13586.api.gong.io).
GONG_BASE_URL=https://api.gong.io

# HTTP server port
PORT=8000
