# Vitally REST API key (Settings → Integrations → Vitally REST API)
# Auth is HTTP Basic: VITALLY_API_KEY as username, no password.
VITALLY_API_KEY=your_api_key_here

# Vitally subdomain (e.g. "dnsfilter" for dnsfilter.rest.vitally.io)
VITALLY_SUBDOMAIN=dnsfilter

# Data center: US or EU. EU uses rest.vitally-eu.io and ignores subdomain.
VITALLY_DATA_CENTER=US

# HTTP server port
PORT=8000
