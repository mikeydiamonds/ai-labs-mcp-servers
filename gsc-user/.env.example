# Google Search Console MCP — per-user OAuth via MintMCP.
# No keys go here for production deploy: MintMCP injects the user's
# access token into the Authorization header on every request.
#
# For local dev only, paste a short-lived access token obtained via
# the OAuth Playground (scopes: webmasters, indexing).
# GSC_ACCESS_TOKEN=

# HTTP server port
PORT=8000
